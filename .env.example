# 斗地主服务端环境变量配置
# 复制此文件为 .env 并根据需要修改
#
# 此文件仅包含 Docker 部署需要的配置
# 本地开发请直接使用 configs/config.yaml

# ===== 端口配置 =====
# WebSocket 服务端口
SERVER_PORT=1780

# Redis 端口
REDIS_PORT=6379

# ===== Docker 专用配置 =====
# Redis 地址（Docker 使用服务名）
REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ===== AI 机器人 =====
# DeepSeek API Key（此 .env 仅 Docker 使用）。
# - 本地开发：放到 .env.local（已 gitignore，代码会自动加载），不要写在这里。
# - Docker：在下方填写，或更安全地用 AI_API_KEY_FILE 指向挂载的 secret 文件。
AI_API_KEY=
# AI_API_KEY_FILE=/run/secrets/ai_api_key

# ===== 优雅关闭超时（分钟）=====
# 等待游戏结束的最长时间
# 建议：54张牌 * 30秒出牌时间 = 27分钟，设置为 30 分钟
# Docker 的 stop_grace_period 会使用此值
GAME_SHUTDOWN_TIMEOUT=30
