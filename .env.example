# 斗地主生产部署环境变量
# 复制为 .env 后，至少检查公开地址和来源白名单。

# ===== 镜像 =====
GAME_IMAGE=gentlekingson/fight-the-landlord
DOUZERO_IMAGE=gentlekingson/fight-the-landlord-douzero
IMAGE_TAG=latest

# ===== 可观测性 =====
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PATH=/metrics
OBSERVABILITY_LOG_FORMAT=json

# ===== 公开端口和来源 =====
SERVER_ENV=production
# 宿主机公开端口。容器内部固定监听 1780。
SERVER_PORT=1780

# 浏览器 WebSocket Origin 白名单，逗号分隔。生产环境必须替换为实际
# HTTPS 地址。Origin 使用 https://，不是 wss://。
SECURITY_ALLOWED_ORIGINS=http://localhost:1780,http://127.0.0.1:1780
# 只有服务确实位于反向代理之后时才设置，例如 10.0.0.0/8。
SECURITY_TRUSTED_PROXY_CIDRS=

# 要求的最低客户端版本，例如 v1.2.0。留空表示不限制。
SERVER_MIN_CLIENT_VERSION=

# ===== Redis =====
REDIS_ADDR=redis:6379
# 必填。生产环境请由 secret manager 注入进程环境，不要写入 .env 或仓库。
REDIS_PASSWORD=
# 可选的本地调试代理端口；必须显式启用 redis-debug profile。
REDIS_DEBUG_PORT=6379
# REDIS_DB=0

# ===== 机器人 =====
BOT_ENABLED=true
BOT_FILL_TIMEOUT=15
DOUZERO_ENABLED=false
DOUZERO_URL=http://douzero:2021

# ===== 游戏和关闭 =====
GAME_TURN_TIMEOUT=30
GAME_BID_TIMEOUT=15
GAME_ROOM_TIMEOUT=10
# 分钟。Compose 的 stop_grace_period 使用相同数值。
GAME_SHUTDOWN_TIMEOUT=30
GAME_SHUTDOWN_CHECK_INTERVAL=15
GAME_ROOM_CLEANUP_DELAY=30
# 牌局中轮到离线玩家行动时的等待秒数；不是会话重连窗口。
# 重连凭证在连接在线时不按墙钟过期，物理断线后固定保留 2 分钟。
GAME_OFFLINE_WAIT_TIMEOUT=30
