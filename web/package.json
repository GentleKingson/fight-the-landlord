{
  "name": "fight-the-landlord-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src tests scripts vite.config.ts vitest.config.ts playwright.config.ts playwright.real.config.ts --max-warnings=0",
    "proto:generate": "node scripts/generate-protocol.mjs",
    "proto:check": "node scripts/generate-protocol.mjs --check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config playwright.real.config.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "protobufjs": "^8.6.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.13",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^26.0.0",
    "protobufjs-cli": "^2.6.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.9"
  }
}
